# === KnowTheClaw Demo API ===

# Port the API listens on (nginx proxies to this)
PORT=3001

# OpenAI API
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Allowed origin for CORS
ALLOWED_ORIGIN=https://knowtheclaw.com

# Rate limiting
MAX_MESSAGES_PER_SESSION=25
MAX_SESSIONS_PER_IP_PER_HOUR=5
MAX_MESSAGE_LENGTH=500

# Session management
SESSION_TIMEOUT_MINUTES=20

# Cost controls
MONTHLY_BUDGET_CENTS=8000
BUDGET_ALERT_PERCENT=80

# Kill switch — set to "true" to disable demo instantly
DEMO_DISABLED=false
DEMO_DISABLED_MESSAGE=The live demo is temporarily offline. Check back soon.

# Logging
LOG_LEVEL=info
